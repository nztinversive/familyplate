{
  "name": "familyplate",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "22.x"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=@familyplate/web",
    "build": "npm run build --workspace=@familyplate/web",
    "start": "npm run start --workspace=@familyplate/web",
    "lint": "npm run lint --workspace=@familyplate/web",
    "store-preview:dev": "npm run dev --workspace=@familyplate/store-preview",
    "store-preview:render": "npm run render --workspace=@familyplate/store-preview",
    "store-preview:poster": "npm run poster --workspace=@familyplate/store-preview",
    "store-preview:still": "npm run still --workspace=@familyplate/store-preview",
    "convex:dev": "convex dev --typecheck=enable",
    "convex:deploy": "convex deploy"
  },
  "devDependencies": {
    "convex": "1.35.1",
    "typescript": "5.9.3"
  }
}
