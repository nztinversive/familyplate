{
  "name": "familyplate",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "22.x"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=@familyplate/web",
    "build": "npm run build --workspace=@familyplate/web",
    "start": "npm run start --workspace=@familyplate/web",
    "lint": "npm run lint --workspace=@familyplate/web",
    "convex:dev": "npm run dev --workspace=@familyplate/convex",
    "convex:deploy": "npm run deploy --workspace=@familyplate/convex"
  }
}
